<?xml version="1.0" encoding="utf-8" ?>
<basePages:BasePage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:basePages="clr-namespace:BilliardIQ.Mobile.Pages.BasePages"
    xmlns:images="clr-namespace:BilliardIQ.Mobile.Models"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:pagemodels="clr-namespace:BilliardIQ.Mobile.PageModels.GamePageModels"
    x:DataType="pagemodels:NewGamePageModel"
    x:Class="BilliardIQ.Mobile.Pages.Games.NewGameViewPage"
    x:Name="NewGame"
    Title="Add New Game">

    <basePages:BasePage.Behaviors>
        <toolkit:EventToCommandBehavior
            x:Name="AppearingBehavior"
            BindingContext="{Binding Source={x:Reference Name=NewGame}, Path=BindingContext}"
            EventName="Appearing"
            Command="{Binding AppearingCommand}" />
    </basePages:BasePage.Behaviors>

    <VerticalStackLayout Padding="15" Spacing="10">

        <!-- Opponent Name -->
        <Entry Text="{Binding OpponentName}" Placeholder="Enter Opponent Name" />
        <Label Text="{Binding OpponentNameError}"
               TextColor="Red"
               IsVisible="{Binding HasOpponentNameError}"
               FontSize="12"
               Margin="4,-6,0,0" />

        <!-- Location -->
        <Entry Text="{Binding Location}" Placeholder="Enter Location" />
        <Label Text="{Binding LocationError}"
               TextColor="Red"
               IsVisible="{Binding HasLocationError}"
               FontSize="12"
               Margin="4,-6,0,0" />

        <!-- Date -->
        <DatePicker Date="{Binding Date}"
                    MinimumDate="{Binding MinimumDate}"
                    MaximumDate="{Binding MaximumDate}"
                    Format="dd.MM.yyyy" />

        <!-- Score -->
        <Label Text="Score" FontAttributes="Bold" />
        <Grid ColumnDefinitions="*, Auto, *" ColumnSpacing="10">
            <VerticalStackLayout Grid.Column="0">
                <Label Text="My Score" HorizontalOptions="Center" FontSize="Caption" />
                <Entry Text="{Binding PlayerScore}"
                       Keyboard="Numeric"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
            <Label Grid.Column="1" Text="–" FontSize="24" VerticalOptions="End" HorizontalOptions="Center" Margin="0,0,0,8" />
            <VerticalStackLayout Grid.Column="2">
                <Label Text="Opponent Score" HorizontalOptions="Center" FontSize="Caption" />
                <Entry Text="{Binding OpponentScore}"
                       Keyboard="Numeric"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>

        <!-- Ball Selection -->
        <Label Text="Select Ball" FontAttributes="Bold" />
        <CollectionView ItemsSource="{Binding Balls}"
                SelectionMode="Single"
                SelectedItem="{Binding Ball}"
                HeightRequest="100">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="20"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="images:ImageData">
                    <Border Padding="8" StrokeThickness="2">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                 Binding="{Binding IsBallSelected}"
                                 Value="True">
                                <Setter Property="Stroke" Value="Green"/>
                                <Setter Property="BackgroundColor" Value="#E8F5E9"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <VerticalStackLayout HorizontalOptions="Center">
                            <Image Source="{Binding Image}" WidthRequest="70" HeightRequest="70"/>
                            <Label Text="{Binding Name}" HorizontalTextAlignment="Center" FontSize="Caption"/>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Label Text="{Binding BallError}"
               TextColor="Red"
               IsVisible="{Binding HasBallError}"
               FontSize="12"
               Margin="4,-6,0,0" />

        <Button Text="{Binding ButtonText}"
                Command="{Binding SaveCommand}"
                Style="{StaticResource PlayerSaveButtonStyle}" />

    </VerticalStackLayout>

</basePages:BasePage>
