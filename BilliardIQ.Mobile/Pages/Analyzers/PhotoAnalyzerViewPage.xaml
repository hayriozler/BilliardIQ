<basePages:BasePage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:basePages="clr-namespace:BilliardIQ.Mobile.Pages.BasePages"
    xmlns:vm="clr-namespace:BilliardIQ.Mobile.PageModels.Analyzers"
    xmlns:local="clr-namespace:BilliardIQ.Mobile.Pages.Analyzers"
    x:Class="BilliardIQ.Mobile.Pages.Analyzers.PhotoAnalyzerViewPage"
    x:DataType="vm:PhotoAnalyzerPageModel">

    <Grid BackgroundColor="Black">

        <!-- Full-screen camera preview (no gestures — handled by overlay) -->
        <toolkit:CameraView x:Name="Camera"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill"
                        SelectedCamera="{Binding SelectedCamera}"/>

        <!-- Transparent gesture overlay: pinch-to-zoom + tap-to-focus -->
        <!-- #01000000 = nearly invisible but receives multi-touch on Android -->
        <Grid x:Name="cameraOverlay"
              HorizontalOptions="Fill"
              VerticalOptions="Fill"
              BackgroundColor="#01000000">
            <Grid.GestureRecognizers>
                <PinchGestureRecognizer PinchUpdated="OnPinchUpdated"/>
                <TapGestureRecognizer Tapped="OnCameraViewTapped"/>
            </Grid.GestureRecognizers>

            <!-- Focus indicator (positioned via TranslationX/Y at tap point) -->
            <Border x:Name="focusIndicator"
                    IsVisible="False"
                    WidthRequest="72"
                    HeightRequest="72"
                    StrokeShape="RoundRectangle 4"
                    Stroke="White"
                    StrokeThickness="2"
                    BackgroundColor="Transparent"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"/>
        </Grid>

        <!-- Close button — top left -->
        <Button Text="✕"
                FontSize="22"
                BackgroundColor="#60000000"
                TextColor="White"
                CornerRadius="24"
                WidthRequest="48"
                HeightRequest="48"
                Padding="0"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                Margin="12,48,0,0"
                Clicked="OnCloseClicked"/>

        <!-- Bottom bar: photo strip + capture controls -->
        <Grid VerticalOptions="End" HorizontalOptions="Fill">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- delete action row -->
                <RowDefinition Height="100"/>    <!-- photo strip -->
                <RowDefinition Height="110"/>    <!-- capture controls -->
            </Grid.RowDefinitions>

            <BoxView Grid.Row="1" BackgroundColor="#88000000"/>
            <BoxView Grid.Row="2" BackgroundColor="#FF000000"/>

            <!-- Delete action (visible when a photo is selected in strip) -->
            <Grid Grid.Row="0"
                  x:Name="photoActions"
                  IsVisible="False"
                  Padding="12,6"
                  BackgroundColor="#88000000"
                  HorizontalOptions="Start">
                <Button Text="🗑"
                        BackgroundColor="#CC3333" TextColor="White"
                        CornerRadius="8" HeightRequest="34" WidthRequest="52"
                        FontSize="14" Padding="0" Clicked="OnDeletePhoto"/>
            </Grid>

            <!-- Horizontal photo strip -->
            <CollectionView Grid.Row="1"
                            x:Name="photoStrip"
                            SelectionMode="Single"
                            SelectionChanged="OnPhotoSelected"
                            Margin="8,8">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="6"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local:CapturedPhoto">
                        <Border WidthRequest="80" HeightRequest="80"
                                StrokeShape="RoundRectangle 8"
                                StrokeThickness="2" Stroke="White"
                                BackgroundColor="Transparent">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Stroke" Value="LimeGreen"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Image Source="{Binding Source}" Aspect="AspectFill"
                                   WidthRequest="80" HeightRequest="80"/>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Capture button — centered -->
            <Border x:Name="captureButton"
                    Grid.Row="2"
                    IsEnabled="False" Opacity="0.4"
                    WidthRequest="80" HeightRequest="80"
                    StrokeShape="RoundRectangle 40"
                    Stroke="White" StrokeThickness="4"
                    BackgroundColor="Transparent"
                    HorizontalOptions="Center" VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding StartCaptureCommand}"/>
                </Border.GestureRecognizers>
                <Ellipse Fill="White" WidthRequest="62" HeightRequest="62"
                         HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
        </Grid>

        <!-- Full-screen photo viewer (shown after capture or from gallery) -->
        <Grid x:Name="photoViewer" IsVisible="False" BackgroundColor="Black">
            <Image x:Name="fullPhoto" Aspect="AspectFit"
                   HorizontalOptions="Fill" VerticalOptions="Fill"/>
            <Button Text="✕"
                    FontSize="22" BackgroundColor="#60000000" TextColor="White"
                    CornerRadius="24" WidthRequest="48" HeightRequest="48"
                    Padding="0" HorizontalOptions="Start" VerticalOptions="Start"
                    Margin="12,48,0,0" Clicked="OnPhotoViewerClose"/>
        </Grid>

    </Grid>

</basePages:BasePage>
