<basePages:BasePage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:basePages="clr-namespace:BilliardIQ.Mobile.Pages.BasePages"
    xmlns:vm="clr-namespace:BilliardIQ.Mobile.PageModels.Analyzers"
    x:Class="BilliardIQ.Mobile.Pages.Analyzers.PhotoAnalyzerViewPage"
    x:DataType="vm:PhotoAnalyzerPageModel">

    <Grid BackgroundColor="Black">

        <!-- Full-screen camera preview -->
        <toolkit:CameraView x:Name="Camera"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill"
                        SelectedCamera="{Binding SelectedCamera}"
                        CameraFlashMode="{Binding FlashMode}">
            <toolkit:CameraView.GestureRecognizers>
                <PinchGestureRecognizer PinchUpdated="OnPinchUpdated"/>
            </toolkit:CameraView.GestureRecognizers>
        </toolkit:CameraView>

        <!-- Rule-of-thirds grid overlay -->
        <GraphicsView x:Name="gridOverlay"
                      HorizontalOptions="Fill"
                      VerticalOptions="Fill"
                      InputTransparent="True"/>

        <!-- Captured photo thumbnail (bottom-left) -->
        <Border x:Name="thumbnailBorder"
                IsVisible="False"
                WidthRequest="88"
                HeightRequest="88"
                StrokeShape="RoundRectangle 10"
                Stroke="White"
                StrokeThickness="2"
                HorizontalOptions="Start"
                VerticalOptions="End"
                Margin="16,0,0,96">
            <Image x:Name="thumbnail"
                   Aspect="AspectFill"
                   WidthRequest="88"
                   HeightRequest="88"/>
        </Border>

        <!-- Debug label -->
        <Label x:Name="debugText"
               VerticalOptions="End"
               HorizontalOptions="Center"
               TextColor="White"
               FontSize="11"
               Margin="0,0,0,8" />

        <!-- Close button — top left -->
        <Button Text="✕"
                FontSize="28"
                BackgroundColor="Transparent"
                TextColor="White"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                Margin="8,20,0,0"
                Clicked="OnCloseClicked" />

        <!-- Right-side controls overlay -->
        <Grid RowDefinitions="Auto,Auto,*"
              HorizontalOptions="End"
              VerticalOptions="Fill"
              WidthRequest="72"
              Padding="0,20,8,24">

            <!-- Flash toggle (top) -->
            <Border Grid.Row="0"
                    Padding="14,10"
                    StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    HorizontalOptions="Center"
                    VerticalOptions="Start">
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding IsFlashOn}" Value="True">
                        <Setter Property="BackgroundColor" Value="#60FFD700"/>
                    </DataTrigger>
                    <DataTrigger TargetType="Border" Binding="{Binding IsFlashOn}" Value="False">
                        <Setter Property="BackgroundColor" Value="#40000000"/>
                    </DataTrigger>
                </Border.Triggers>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ToggleFlashCommand}"/>
                </Border.GestureRecognizers>
                <Label FontSize="22" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsFlashOn}" Value="True">
                            <Setter Property="Text" Value="⚡"/>
                            <Setter Property="Opacity" Value="1"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Label" Binding="{Binding IsFlashOn}" Value="False">
                            <Setter Property="Text" Value="⚡"/>
                            <Setter Property="Opacity" Value="0.45"/>
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </Border>

            <!-- Flip camera button (below flash) -->
            <Border Grid.Row="1"
                    Padding="14,10"
                    Margin="0,8,0,0"
                    StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    BackgroundColor="#40000000"
                    HorizontalOptions="Center"
                    VerticalOptions="Start">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ToggleCameraCommand}"/>
                </Border.GestureRecognizers>
                <Label Text="🔄" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

            <!-- Capture button (center) -->
            <Border x:Name="captureButton"
                Grid.Row="2"
                IsEnabled="False"
                Opacity="0.4"
                WidthRequest="70"
                HeightRequest="70"
                StrokeShape="RoundRectangle 35"
                Stroke="White"
                StrokeThickness="4"
                BackgroundColor="Transparent"
                HorizontalOptions="Center"
                VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding StartCaptureCommand}"/>
                </Border.GestureRecognizers>
                <Ellipse Fill="White"
                     WidthRequest="52"
                     HeightRequest="52"
                     HorizontalOptions="Center"
                     VerticalOptions="Center"/>
            </Border>

        </Grid>


    </Grid>

</basePages:BasePage>
