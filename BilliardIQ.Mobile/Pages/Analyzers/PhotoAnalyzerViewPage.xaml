<basePages:BasePage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:basePages="clr-namespace:BilliardIQ.Mobile.Pages.BasePages"
    xmlns:vm="clr-namespace:BilliardIQ.Mobile.PageModels.Analyzers"
    x:Class="BilliardIQ.Mobile.Pages.Analyzers.PhotoAnalyzerViewPage"
    x:DataType="vm:PhotoAnalyzerPageModel">
    <Grid ColumnDefinitions="80, *, 120" RowDefinitions="*" BackgroundColor="Black">

        <VerticalStackLayout Grid.Column="0"
                         VerticalOptions="Start"
                         HorizontalOptions="Center"
                         Padding="0,20">
            <Button Text="✕"
                FontSize="28"
                BackgroundColor="Transparent"
                TextColor="White"
                Clicked="OnCloseClicked" />
        </VerticalStackLayout>

        <Grid Grid.Column="1" HorizontalOptions="Fill" VerticalOptions="Fill">
            <toolkit:CameraView x:Name="Camera"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill"
                            SelectedCamera="{Binding SelectedCamera}" />
            <Image x:Name="image"
                   HorizontalOptions="Fill"
                   VerticalOptions="Fill"
                   Aspect="AspectFit"
                   IsVisible="{Binding Source={x:Reference image}, Path=Source, Converter={toolkit:IsNotNullConverter}}" />
            <Label x:Name="debugText"
                   VerticalOptions="End"
                   HorizontalOptions="Center"
                   TextColor="White"
                   FontSize="11"
                   Margin="0,0,0,8" />
        </Grid>

        <Grid Grid.Column="2" RowDefinitions="Auto, *, Auto" Padding="10">


            <Border Grid.Row="1"
                WidthRequest="80" 
                HeightRequest="80"
                StrokeShape="RoundRectangle 40"
                Stroke="White"
                StrokeThickness="4"
                BackgroundColor="Transparent"
                HorizontalOptions="Center"
                VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCaptureClicked"/>
                </Border.GestureRecognizers>

                <Ellipse Fill="White" 
                     WidthRequest="60" 
                     HeightRequest="60" 
                     HorizontalOptions="Center" 
                     VerticalOptions="Center"/>
            </Border>

            <VerticalStackLayout Grid.Row="2" VerticalOptions="End" Spacing="10" Padding="0,0,0,20">
                <Border Padding="12,4" StrokeShape="RoundRectangle 15" HorizontalOptions="Center"
                        BackgroundColor="{Binding IsBackCameraSelected, Converter={toolkit:IsNotNullConverter}}">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsBackCameraSelected}" Value="True">
                            <Setter Property="BackgroundColor" Value="#40FFFFFF"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsBackCameraSelected}" Value="False">
                            <Setter Property="BackgroundColor" Value="Transparent"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectBackCameraCommand}"/>
                    </Border.GestureRecognizers>
                    <Label TextColor="White" FontSize="12" HorizontalOptions="Center">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsBackCameraSelected}" Value="True">
                                <Setter Property="Text" Value="Back Camera"/>
                                <Setter Property="FontAttributes" Value="Bold"/>
                                <Setter Property="Opacity" Value="1"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsBackCameraSelected}" Value="False">
                                <Setter Property="Text" Value="Back Camera"/>
                                <Setter Property="FontAttributes" Value="None"/>
                                <Setter Property="Opacity" Value="0.5"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>
                <Border Padding="12,4" StrokeShape="RoundRectangle 15" HorizontalOptions="Center"
                        BackgroundColor="Transparent">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsBackCameraSelected}" Value="False">
                            <Setter Property="BackgroundColor" Value="#40FFFFFF"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsBackCameraSelected}" Value="True">
                            <Setter Property="BackgroundColor" Value="Transparent"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectFrontCameraCommand}"/>
                    </Border.GestureRecognizers>
                    <Label TextColor="White" FontSize="12" HorizontalOptions="Center">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsBackCameraSelected}" Value="False">
                                <Setter Property="Text" Value="Front Camera"/>
                                <Setter Property="FontAttributes" Value="Bold"/>
                                <Setter Property="Opacity" Value="1"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsBackCameraSelected}" Value="True">
                                <Setter Property="Text" Value="Front Camera"/>
                                <Setter Property="FontAttributes" Value="None"/>
                                <Setter Property="Opacity" Value="0.5"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>
            </VerticalStackLayout>

        </Grid>

    </Grid>

</basePages:BasePage>
