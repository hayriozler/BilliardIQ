<?xml version="1.0" encoding="utf-8" ?>
<basePages:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:basePages="clr-namespace:BilliardIQ.Mobile.Pages.BasePages"
             xmlns:pageModels="clr-namespace:BilliardIQ.Mobile.PageModels"
             xmlns:controls="clr-namespace:BilliardIQ.Mobile.Pages.Controls"
             x:DataType="pageModels:MainPageModel"
             x:Class="BilliardIQ.Mobile.Pages.MainViewPage">
    <Grid>
        <controls:NewPhotoButton
            IsEnabled="True"
            Command="{Binding TakePhotoCommand}"
            ToolTipProperties.Text="New Photo"
            SemanticProperties.Description="New Photo"
            VerticalOptions="Start"
            HorizontalOptions="End" />
    </Grid>
</basePages:BasePage>
