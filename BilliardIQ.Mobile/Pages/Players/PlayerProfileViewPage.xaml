<?xml version="1.0" encoding="utf-8" ?>
<basePage:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:basePage="clr-namespace:BilliardIQ.Mobile.Pages.BasePages"
             xmlns:pages="clr-namespace:BilliardIQ.Mobile.Pages.Players"
             xmlns:pagemodels="clr-namespace:BilliardIQ.Mobile.PageModels.PlayerPageModels"
             x:DataType="pagemodels:PlayerProfilePageModel"
             x:Class="BilliardIQ.Mobile.Pages.Players.PlayerProfileViewPage"
             x:Name="PlayerProfilePage"
             Title="{Binding L[Profile_Title]}">

    <basePage:BasePage.Behaviors>
        <toolkit:EventToCommandBehavior
            x:Name="AppearingBehavior"
            BindingContext="{Binding Source={x:Reference Name=PlayerProfilePage}, Path=BindingContext}"
            EventName="Appearing"
            Command="{Binding AppearingCommand}" />
    </basePage:BasePage.Behaviors>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label Text="{Binding HeaderText}"
                   FontSize="22" FontAttributes="Bold" HorizontalOptions="Center"/>

            <!-- Name -->
            <Entry Text="{Binding FirstName, Mode=TwoWay}" Placeholder="{Binding L[Profile_Name]}" />
            <Label Text="{Binding FirstNameError}" TextColor="Red"
                   IsVisible="{Binding HasFirstNameError}" FontSize="12"/>

            <!-- Surname -->
            <Entry Text="{Binding Surname, Mode=TwoWay}" Placeholder="{Binding L[Profile_Surname]}" />
            <Label Text="{Binding LastNameError}" TextColor="Red"
                   IsVisible="{Binding HasLastNameError}" FontSize="12"/>

            <!-- Country Picker -->
            <Label Text="{Binding L[Profile_Country]}" FontSize="13" TextColor="Gray"/>
            <Picker Title="{Binding L[Profile_SelectCountry]}"
                    ItemsSource="{Binding Countries}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding SelectedCountry}" />
            <Label Text="{Binding CountryError}" TextColor="Red"
                   IsVisible="{Binding HasCountryError}" FontSize="12"/>

            <!-- City — searchable modal -->
            <Label Text="{Binding L[Profile_City]}" FontSize="13" TextColor="Gray"/>
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}"
                    Padding="12,0"
                    HeightRequest="44">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8"/>
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectCityCommand}"
                                          NumberOfTapsRequired="1" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0"
                           Text="{Binding CityDisplayText}"
                           VerticalOptions="Center"
                           FontSize="16" />
                    <Label Grid.Column="1"
                           Text="&#x25BC;"
                           FontSize="12"
                           TextColor="Gray"
                           VerticalOptions="Center" />
                </Grid>
            </Border>
            <Label Text="{Binding CityError}" TextColor="Red"
                   IsVisible="{Binding HasCityError}" FontSize="12"/>

            <!-- Club (optional) -->
            <Entry Text="{Binding Club, Mode=TwoWay}" Placeholder="{Binding L[Profile_Club]}" />

            <!-- Association (optional) -->
            <Entry Text="{Binding Association, Mode=TwoWay}" Placeholder="{Binding L[Profile_Association]}" />

            <!-- Email -->
            <Entry Text="{Binding Email, Mode=TwoWay}" Placeholder="{Binding L[Profile_Email]}" />
            <Label Text="{Binding EmailError}" TextColor="Red"
                   IsVisible="{Binding HasEmailError}" FontSize="12"/>

            <!-- Phone (optional) -->
            <Entry Text="{Binding Phone, Mode=TwoWay}" Placeholder="{Binding L[Profile_Phone]}" Keyboard="Telephone" />

            <!-- Level Picker -->
            <Label Text="{Binding L[Profile_Level]}" FontSize="13" TextColor="Gray"/>
            <Picker Title="{Binding L[Profile_SelectLevel]}"
                    ItemsSource="{Binding Levels}"
                    SelectedItem="{Binding SelectedLevel}" />

            <!-- Language Picker -->
            <Label Text="{Binding L[Profile_Language]}" FontSize="13" TextColor="Gray"/>
            <Picker ItemsSource="{Binding Languages}"
                    SelectedItem="{Binding SelectedLanguageName}" />

            <!-- Save button (new player) -->
            <Button Text="{Binding L[Action_Save]}"
                    ImageSource="{StaticResource IconSave}"
                    ContentLayout="Left,10"
                    Command="{Binding UpsertCommand}"
                    Style="{StaticResource PlayerSaveButtonStyle}"
                    IsVisible="{Binding IsUpdateMode, Converter={toolkit:InvertedBoolConverter}}" />

            <!-- Update button (existing player) -->
            <Button Text="{Binding L[Action_Update]}"
                    ImageSource="{StaticResource IconEdit}"
                    ContentLayout="Left,10"
                    Command="{Binding UpsertCommand}"
                    Style="{StaticResource PlayerSaveButtonStyle}"
                    IsVisible="{Binding IsUpdateMode}" />

        </VerticalStackLayout>
    </ScrollView>

</basePage:BasePage>
