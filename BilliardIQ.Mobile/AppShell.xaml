<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BilliardIQ.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:games="clr-namespace:BilliardIQ.Mobile.Pages.Games"
    xmlns:players="clr-namespace:BilliardIQ.Mobile.Pages.Players"
    xmlns:pages="clr-namespace:BilliardIQ.Mobile.Pages"
    Shell.FlyoutBehavior="Flyout"
    Title="BilliardIQ">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate pages:MainViewPage}"
        Route="home" />
    
    
    <ShellContent
    Title="Game"
    ContentTemplate="{DataTemplate games:GameListViewPage}"
    Route="gamelist" />

    <ShellContent
        Title="Profile"
        ContentTemplate="{DataTemplate players:PlayerProfileViewPage}"
        Route="profile" />
</Shell>
