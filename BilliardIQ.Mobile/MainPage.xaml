<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BilliardIQ.Mobile.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30"
            Spacing="20">

            <Label
                Text="BilliardIQ"
                FontSize="28"
                FontAttributes="Bold"
                HorizontalOptions="Center" />

            <Label
                Text="Masayı fotoğraflayın, en iyi vuruşu analiz edelim 🎱"
                FontSize="14"
                HorizontalOptions="Center" />

            <Button
                Text="📸 Foto Se"
                Command="{Binding PickPhotoCommand}"
                HeightRequest="55"
                BackgroundColor="#2563EB"
                TextColor="White"
                CornerRadius="12" />

            <Border
                Padding="10"
                BackgroundColor="#ddd"
                Shadow="false">
                <Image
                    HeightRequest="300"
                    Aspect="AspectFit"
                    Source="{Binding SelectedImage}" />
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
